<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetClinicApp.Desktop.MainPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <!-- Header -->
            <Label Text="🐾 Pet Clinic Dashboard"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Tertiary}"
                   HorizontalOptions="Center" />

            <Label Text="Welcome to Pet Grooming &amp; Veterinary Appointment Scheduler"
                   FontSize="16"
                   TextColor="{StaticResource Gray500}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,10" />

            <!-- Summary Cards -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">

                <!-- Total Pets Card -->
                <Border Grid.Column="0"
                        Stroke="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="2"
                        Padding="20"
                        BackgroundColor="{AppThemeBinding Light=#F0FAF8, Dark=#1A2E2B}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="🐕" FontSize="32" HorizontalOptions="Center" />
                        <Label x:Name="LblTotalPets"
                               Text="0"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center" />
                        <Label Text="Registered Pets"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Total Clients Card -->
                <Border Grid.Column="1"
                        Stroke="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="2"
                        Padding="20"
                        BackgroundColor="{AppThemeBinding Light=#FDF8EC, Dark=#2E2A1A}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="👤" FontSize="32" HorizontalOptions="Center" />
                        <Label x:Name="LblTotalClients"
                               Text="0"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Warning}"
                               HorizontalOptions="Center" />
                        <Label Text="Total Clients"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Earnings Card -->
                <Border Grid.Column="2"
                        Stroke="{StaticResource Info}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="2"
                        Padding="20"
                        BackgroundColor="{AppThemeBinding Light=#EEF4F8, Dark=#1A222E}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="💰" FontSize="32" HorizontalOptions="Center" />
                        <Label x:Name="LblTotalEarnings"
                               Text="$0.00"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Info}"
                               HorizontalOptions="Center" />
                        <Label Text="Total Earnings"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,10" />

            <!-- Clinic Summary -->
            <Border Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📊 Clinic Summary"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Tertiary}" />
                    <Label x:Name="LblClinicSummary"
                           Text="Loading summary..."
                           FontSize="14"
                           TextColor="{StaticResource Gray600}" />
                </VerticalStackLayout>
            </Border>

            <!-- Quick Actions -->
            <Label Text="Quick Actions"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Tertiary}"
                   Margin="0,10,0,0" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <Button Grid.Column="0"
                        Text="➕ Add New Client"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Clicked="OnGoToClientsClicked" />
                <Button Grid.Column="1"
                        Text="🐾 Add New Pet"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource Tertiary}"
                        Clicked="OnGoToPetsClicked" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
